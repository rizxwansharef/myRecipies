<h1>Chef profile</h1>

<div class="mb-3">
  <strong>Name:</strong>
  <%= @chef.name %>
</div>

<div class="mb-3">
  <strong>Email:</strong>
  <%= @chef.email %>
</div>

<div class="d-flex gap-2">
    
        <%= link_to "Edit profile", edit_chef_path(@chef), class: "btn btn-primary" %>
        <%= link_to "View Recipes", recipes_path, class: "btn btn-outline-secondary" %>
</div>
