<div class="container py-5">
	<h1 class="mb-4">New Ingredient</h1>

	<%= form_with model: @ingredient, local: true do |form| %>
		<% if @ingredient.errors.any? %>
			<div class="alert alert-danger">
				<h4><%= pluralize(@ingredient.errors.count, "error") %> prevented this ingredient from being saved:</h4>
				<ul class="mb-0">
					<% @ingredient.errors.full_messages.each do |message| %>
						<li><%= message %></li>
					<% end %>
				</ul>
			</div>
		<% end %>

		<div class="mb-3">
			<%= form.label :name, class: "form-label" %>
			<%= form.text_field :name, class: "form-control", required: true %>
		</div>

		<div class="d-flex gap-2">
			<%= form.submit class: "btn btn-primary" %>
			<%= link_to "Cancel", ingredients_path, class: "btn btn-outline-secondary" %>
		</div>
	<% end %>
</div>
