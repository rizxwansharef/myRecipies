<%= form_with model: @recipe, local: true do |form| %>
  <% show_new_ingredient_field = local_assigns.fetch(:show_new_ingredient_field, false) %>

  <% if @recipe.errors.any? %>
    <div class="alert alert-danger">
      <h4><%= pluralize(@recipe.errors.count, "error") %> prevented this recipe from being saved:</h4>
      <ul>
        <% @recipe.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :name, class: "form-label" %>
    <%= form.text_field :name, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= form.label :description, class: "form-label" %>
    <%= form.text_area :description, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <label class="form-label d-block">Ingredients</label>
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-2">
      <%= form.collection_check_boxes :ingredient_ids, @ingredients, :id, :name do |builder| %>
        <div class="col">
          <div class="form-check border rounded p-2 h-100">
            <%= builder.check_box class: "form-check-input me-2" %>
            <%= builder.label class: "form-check-label" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

    <% if show_new_ingredient_field %>
      <div class="mb-3">
        <button id="show-new-ingredient-toggle" type="button" class="btn btn-sm btn-outline-secondary mb-2" aria-expanded="false">Add new ingredient(s)</button>

        <div id="new-ingredient-wrapper" style="display:none;">
          <div class="mb-2">
            <div id="new-ingredient-fields">
              <div class="input-group mb-2">
                <input type="text" name="recipe[new_ingredient_names][]" class="form-control" placeholder="Type a new ingredient name" />
              </div>
            </div>
            <div class="d-flex gap-2">
              <button id="add-ingredient-field" type="button" class="btn btn-sm btn-secondary">Add another ingredient</button>
            </div>
          </div>
        </div>
      </div>

      <script>
        (function(){
          var toggle = document.getElementById('show-new-ingredient-toggle');
          var wrapper = document.getElementById('new-ingredient-wrapper');
          var addBtn = document.getElementById('add-ingredient-field');
          var container = document.getElementById('new-ingredient-fields');
          if (!toggle) return;

          toggle.addEventListener('click', function(){
            var isVisible = wrapper.style.display !== 'none';
            wrapper.style.display = isVisible ? 'none' : '';
            toggle.setAttribute('aria-expanded', (!isVisible).toString());
            if (!isVisible) {
              // focus the first input when opening
              var first = container.querySelector('input');
              if (first) first.focus();
            }
          });

          if (addBtn && container) {
            addBtn.addEventListener('click', function(){
              var newWrap = document.createElement('div');
              newWrap.className = 'input-group mb-2';
              var input = document.createElement('input');
              input.type = 'text';
              input.name = 'recipe[new_ingredient_names][]';
              input.className = 'form-control';
              input.placeholder = 'Type a new ingredient name';
              newWrap.appendChild(input);
              container.appendChild(newWrap);
              input.focus();
            });
          }
        })();
      </script>
    <% end %>

  <div class="d-flex gap-2">
    <%= form.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", root_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>