<div class="col-md-6 col-lg-4">
  <div class="card h-100 shadow-sm">
    <div class="card-body d-flex flex-column">
      <h2 class="h5 card-title"><%= recipe.name %></h2>
      <p class="card-text text-truncate"><%= recipe.description %></p>
      <p class="text-muted mb-3">
        Chef: <strong><%= recipe.chef&.name || "Unknown" %></strong>
      </p>
      <p class="text-muted mb-3">
        <%= pluralize(recipe.comments.size, "comment") %>
      </p>
      <div class="mt-auto">
        <%= link_to "View Recipe", recipe_path(recipe), class: "btn btn-outline-primary me-2" %>
        <% if logged_in? && authorized_for_recipecrud?(recipe) %>
          <%= link_to "Edit", edit_recipe_path(recipe), class: "btn btn-secondary me-2" %>
        <% end %>

        <% if authorized_for_admin? %>
          <%= button_to "Delete", recipe_path(recipe), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-danger me-2", form: { class: "d-inline" } %>
        <% end %>
      </div>
    </div>
  </div>
</div>