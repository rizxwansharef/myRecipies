<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="mb-0">Recipes</h1>
      <% if params[:chef_id].blank? && logged_in? %>
        <p class="text-muted mb-0">Your recipes first, then recipes from other chefs.</p>
      <% else %>
        <p class="text-muted mb-0">Showing recipes</p>
      <% end %>
    </div>
    <%= link_to "New Recipe", new_recipe_path, class: "btn btn-primary" %>
  </div>

  <% if params[:chef_id].present? %>
    <% if @recipes.any? %>
      <div class="row g-4">
        <%= render partial: "recipe_card", collection: @recipes, as: :recipe %>
      </div>
    <% else %>
      <div class="alert alert-info" role="alert">
        No recipes found yet. Add one to get started.
      </div>
    <% end %>
  <% else %>
    <% if logged_in? %>
      <div class="mb-5">
        <h2 class="h4 mb-3">My Recipes</h2>
        <% if @my_recipes.any? %>
          <div class="row g-4">
            <%= render partial: "recipe_card", collection: @my_recipes, as: :recipe %>
          </div>
        <% else %>
          <div class="alert alert-info" role="alert">
            You have not added any recipes yet.
          </div>
        <% end %>
      </div>
    <% end %>

    <div>
      <h2 class="h4 mb-3"><%= logged_in? ? "Recipes by Other Chefs" : "Recipes" %></h2>
      <% if @other_recipes.any? %>
        <div class="row g-4">
          <%= render partial: "recipe_card", collection: @other_recipes, as: :recipe %>
        </div>
      <% else %>
        <div class="alert alert-info" role="alert">
          No recipes found yet. Add one to get started.
        </div>
      <% end %>
    </div>
  <% end %>
</div>
