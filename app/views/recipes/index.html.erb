<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="mb-0">Recipes</h1>
        <p class="text-muted">Showing recipes </p>
        <%= current_chef.id %>
    
    </div>
    <%= link_to "New Recipe", new_recipe_path, class: "btn btn-primary" %>
  </div>

  <% if @recipes.any? %>
    <div class="row g-4">
      <% @recipes.each do |recipe| %>
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
              <h2 class="h5 card-title"><%= recipe.name %></h2>
              <p class="card-text text-truncate"><%= recipe.description %></p>
              <p class="text-muted mb-3">
                Chef: <strong><%= recipe.chef&.name || "Unknown" %></strong>
              </p>
              <%= recipe.chef_id %>
              <div class="mt-auto">
            
                <%= link_to "View Recipe", recipe_path(recipe), class: "btn btn-outline-primary me-2" %>
                <% if logged_in? && authorized_for_recipecrud?(recipe) %>
                  <%= link_to "Edit", edit_recipe_path(recipe),  class: "btn btn-secondary me-2" %>
                 <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-info" role="alert">
      No recipes found yet. Add one to get started.
    </div>
  <% end %>
</div>
