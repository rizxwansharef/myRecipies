<div class="container py-5">
    <div class="mb-4">
        <%= link_to "← Back to Recipes", recipes_path, class: "btn btn-link" %>
    </div>

  <div class="card shadow-sm">
        <div class="card-body">
            <h1 class="card-title"><%= @recipe.name %></h1>
            <p class="text-muted mb-3">
                Chef: <strong><%= @recipe.chef&.name || "Unknown" %></strong>
            </p>
            <p class="card-text"><%= @recipe.description %></p>

        </div>

    </div>
    <div class="mt-3">
        <% if authorized_for_recipecrud?(@recipe) %>

            <%= link_to "Edit", edit_recipe_path(@recipe), class: "btn btn-secondary me-2" %>
            <%= button_to "Delete", destroy_recipe_path(@recipe), method: :delete, class: "btn btn-danger", form: { class: "d-inline" } %>
        <% end %>
    </div>

</div>

